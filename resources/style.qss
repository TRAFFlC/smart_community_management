/* ============================================================
   智慧社区管理平台 — 全局样式表 v5.0
   设计方向: 「现代档案室 / Modern Archive」
   ------------------------------------------------------------
   灵感来源: Claude Design Skill (editorial research-journal style)
   核心理念: 暖象牙白底 + 近黑墨色 + 单一琥珀强调
            靠排版、对比、间距建立权威感，而非装饰
   ------------------------------------------------------------
   Design Tokens
   ------------------------------------------------------------
   颜色:
     页面背景 (paper):   #FAF9F6  (暖象牙白，非纯白)
     卡片表面 (surface): #FFFFFF  (仅用于约束性表面)
     墨色 (ink):         #141413  (近黑，文字/边框/深色面板)
     深墨 (inkDeep):     #0A0A0A  (侧边栏背景)
     次级文字 (muted):   #6B6B6B
     辅助文字 (faint):   #9A9A9A
     分割线 (rule):      #D4D0C8  (暖灰)
     细边框 (hairline):  #E8E5DE  (极浅暖灰)
     强调色 (accent):    #92400E  (深琥珀，克制)
     强调悬浮 (accentH): #B45309  (琥珀)
     成功:               #16A34A
     警告:               #D97706
     危险:               #DC2626
     信息:               #2563EB
   字体:
     标题: Noto Serif SC (思源宋体) SemiBold/Bold
     正文: Noto Sans SC (思源黑体) Regular
     数字: "Cascadia Code", "DejaVu Sans Mono", monospace
     H1: 28px / 700 (衬线)
     H2: 20px / 600 (衬线)
     H3: 16px / 600 (无衬线)
     Body: 14px / 400
     Caption: 12px / 400
     Data: 36px / 700 (等宽)
   间距: 4px 网格基准
   圆角: 全局 2px（克制，非 4-8px）
   边框: 1px 实色细边框，极少阴影
   ============================================================ */

/* ---- 全局基础 ---- */
QWidget {
    background-color: #FAF9F6;
    font-family: "Noto Sans SC", "Microsoft YaHei UI", "Microsoft YaHei", "PingFang SC", "Segoe UI", sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #141413;
}

/* 标题用衬线字体 — 通过 objectName 标识 */
QLabel#serifTitle, QLabel[fontRole="serif"] {
    font-family: "Noto Serif SC", "Source Han Serif SC", "SimSun", serif;
}

/* 等宽数字 — 通过 objectName 标识 */
QLabel#monoNumber, QLabel[fontRole="mono"], QLabel[fontRole="data"] {
    font-family: "Cascadia Code", "JetBrains Mono", "DejaVu Sans Mono", "Consolas", monospace;
    font-variant-numeric: tabular-nums;
}

/* ---- 滚动条：极简细线 ---- */
QScrollBar:vertical {
    width: 8px;
    background: transparent;
    margin: 0;
    border: none;
}
QScrollBar::handle:vertical {
    background: #D4D0C8;
    border-radius: 0;
    min-height: 40px;
}
QScrollBar::handle:vertical:hover {
    background: #9A9A9A;
}
QScrollBar::handle:vertical:pressed {
    background: #6B6B6B;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
    border: none;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: transparent;
}

QScrollBar:horizontal {
    height: 8px;
    background: transparent;
    margin: 0;
    border: none;
}
QScrollBar::handle:horizontal {
    background: #D4D0C8;
    border-radius: 0;
    min-width: 40px;
}
QScrollBar::handle:horizontal:hover {
    background: #9A9A9A;
}
QScrollBar::handle:horizontal:pressed {
    background: #6B6B6B;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
    border: none;
}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: transparent;
}

/* ---- 表格：数据表格而非卡片列表 ---- */
QTableWidget {
    background: #FFFFFF;
    border: 1px solid #D4D0C8;
    border-radius: 2px;
    gridline-color: transparent;
    selection-background-color: rgba(146, 64, 14, 0.06);
    selection-color: #141413;
    alternate-background-color: #FAF9F6;
    outline: none;
}
QTableWidget::item {
    padding: 0 16px;
    min-height: 44px;
    border-bottom: 1px solid #E8E5DE;
    font-size: 14px;
    color: #141413;
}
QTableWidget::item:alternate {
    background: #FAF9F6;
}
QTableWidget::item:hover {
    background: #F5F2EB;
}
QTableWidget::item:selected {
    background: rgba(146, 64, 14, 0.06);
    color: #141413;
}
QHeaderView::section {
    background: #141413;
    color: #FAF9F6;
    padding: 0 16px;
    min-height: 36px;
    border: none;
    border-right: 1px solid #2A2A2A;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
}
QHeaderView::section:last {
    border-right: none;
}
QHeaderView::section:hover {
    background: #2A2A2A;
}

/* 排序指示器 — 琥珀色 */
QHeaderView::up-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 5px solid #B45309;
    width: 0;
    height: 0;
}
QHeaderView::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #B45309;
    width: 0;
    height: 0;
}

/* ---- 按钮系统：克制、硬朗 ---- */
QPushButton {
    border-radius: 2px;
    padding: 8px 18px;
    font-size: 14px;
    font-weight: 500;
    background: #FFFFFF;
    color: #141413;
    border: 1px solid #141413;
    min-height: 36px;
}
QPushButton:hover {
    background: #141413;
    color: #FAF9F6;
    border-color: #141413;
}
QPushButton:pressed {
    background: #0A0A0A;
    color: #FAF9F6;
}
QPushButton:focus {
    outline: none;
    border-color: #92400E;
}
QPushButton:disabled {
    background: #F5F2EB;
    color: #9A9A9A;
    border-color: #D4D0C8;
}

/* 表格内按钮 — 紧凑 */
QTableWidget QPushButton, QTreeWidget QPushButton,
QTableWidget QWidget QPushButton, QTreeWidget QWidget QPushButton {
    min-height: 22px !important;
    max-height: 26px !important;
    min-width: 0px;
    max-width: 80px;
    padding: 2px 10px !important;
    font-size: 12px;
    border: 1px solid #D4D0C8;
    border-radius: 2px;
    background: transparent;
    color: #141413;
}
QTableWidget QPushButton:hover, QTreeWidget QPushButton:hover,
QTableWidget QWidget QPushButton:hover, QTreeWidget QWidget QPushButton:hover {
    border-color: #141413;
    background: #141413;
    color: #FAF9F6;
}

/* Large 按钮 (40px) */
QPushButton[cssClass="large"] {
    min-height: 40px;
    padding: 10px 24px;
    font-size: 15px;
}
/* Small 按钮 (28px) */
QPushButton[cssClass="small"] {
    min-height: 28px;
    padding: 4px 12px;
    font-size: 13px;
}
/* 主按钮 — 深墨色实心 */
QPushButton[cssClass="primary"] {
    background: #141413;
    color: #FAF9F6;
    border: 1px solid #141413;
}
QPushButton[cssClass="primary"]:hover {
    background: #92400E;
    border-color: #92400E;
    color: #FAF9F6;
}
QPushButton[cssClass="primary"]:pressed {
    background: #6B3008;
    border-color: #6B3008;
}
QPushButton[cssClass="primary"]:disabled {
    background: #D4D0C8;
    border-color: #D4D0C8;
    color: #9A9A9A;
}
/* 危险按钮 */
QPushButton[cssClass="danger"] {
    background: #DC2626;
    color: #FFFFFF;
    border: 1px solid #DC2626;
}
QPushButton[cssClass="danger"]:hover {
    background: #B91C1C;
    border-color: #B91C1C;
    color: #FFFFFF;
}
QPushButton[cssClass="danger"]:pressed {
    background: #991B1B;
    border-color: #991B1B;
}
QPushButton[cssClass="danger"]:disabled {
    background: #F5F2EB;
    border-color: #D4D0C8;
    color: #9A9A9A;
}
/* 文字按钮 — 琥珀色链接 */
QPushButton[cssClass="text"] {
    background: transparent;
    border: none;
    color: #92400E;
    padding: 4px 8px;
}
QPushButton[cssClass="text"]:hover {
    background: rgba(146, 64, 14, 0.06);
    border: none;
    color: #6B3008;
}
QPushButton[cssClass="text"]:pressed {
    color: #4A2008;
}

/* ---- 输入框系统：下划线感 ---- */
QLineEdit {
    border: none;
    border-bottom: 1px solid #D4D0C8;
    border-radius: 0;
    padding: 8px 4px;
    background: transparent;
    color: #141413;
    selection-background-color: #92400E;
    selection-color: #FAF9F6;
    min-height: 28px;
}
QLineEdit:hover {
    border-bottom: 1px solid #6B6B6B;
}
QLineEdit:focus {
    border-bottom: 2px solid #92400E;
    padding-bottom: 7px;
}
QLineEdit:disabled {
    background: #F5F2EB;
    color: #9A9A9A;
    border-bottom: 1px solid #E8E5DE;
}
QLineEdit[readOnly="true"] {
    color: #6B6B6B;
}

/* 带边框输入框变体 — 用于搜索栏等 */
QLineEdit[variant="boxed"] {
    border: 1px solid #D4D0C8;
    border-radius: 2px;
    padding: 8px 14px;
    background: #FFFFFF;
}
QLineEdit[variant="boxed"]:hover {
    border-color: #6B6B6B;
}
QLineEdit[variant="boxed"]:focus {
    border: 1px solid #92400E;
    padding: 8px 14px;
}

QTextEdit {
    border: 1px solid #D4D0C8;
    border-radius: 2px;
    padding: 10px 14px;
    background: #FFFFFF;
    color: #141413;
    selection-background-color: #92400E;
    selection-color: #FAF9F6;
}
QTextEdit:hover {
    border-color: #6B6B6B;
}
QTextEdit:focus {
    border-color: #92400E;
}

/* ---- 下拉框 ---- */
QComboBox {
    border: 1px solid #D4D0C8;
    border-radius: 2px;
    padding: 8px 14px;
    background: #FFFFFF;
    color: #141413;
    min-height: 36px;
}
QComboBox:hover {
    border-color: #6B6B6B;
}
QComboBox:focus {
    border-color: #92400E;
}
QComboBox:disabled {
    background: #F5F2EB;
    color: #9A9A9A;
}
QComboBox::drop-down {
    border: none;
    width: 28px;
    subcontrol-position: center right;
}
QComboBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #141413;
    margin-right: 10px;
}
QComboBox QAbstractItemView {
    background: #FFFFFF;
    border: 1px solid #141413;
    border-radius: 0;
    selection-background-color: #141413;
    selection-color: #FAF9F6;
    outline: none;
    padding: 4px 0;
}
QComboBox QAbstractItemView::item {
    padding: 10px 14px;
    min-height: 36px;
}
QComboBox QAbstractItemView::item:hover {
    background: #F5F2EB;
}
QComboBox QAbstractItemView::item:selected {
    background: #141413;
    color: #FAF9F6;
}

/* ---- 分组框：档案卡片感 ---- */
QGroupBox {
    font-family: "Noto Serif SC", "Source Han Serif SC", "SimSun", serif;
    font-weight: 600;
    font-size: 16px;
    color: #141413;
    margin-top: 16px;
    padding: 24px 18px 18px 18px;
    border: 1px solid #D4D0C8;
    border-radius: 2px;
    background: #FFFFFF;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 18px;
    padding: 0 8px;
    background: #FAF9F6;
    color: #141413;
}

/* ---- 标签页：编辑器风格 ---- */
QTabWidget::pane {
    border: none;
    border-top: 1px solid #D4D0C8;
    background: #FFFFFF;
}
QTabBar::tab {
    background: transparent;
    color: #6B6B6B;
    padding: 12px 20px;
    border: none;
    border-bottom: 2px solid transparent;
    margin-right: 0;
    font-size: 14px;
    font-weight: 500;
    outline: none;
}
QTabBar::tab:hover {
    color: #141413;
}
QTabBar::tab:selected {
    color: #141413;
    border-bottom: 2px solid #92400E;
    font-weight: 600;
}
QTabBar::tab:focus {
    border: none;
    outline: none;
}

/* ---- 树形控件 ---- */
QTreeWidget {
    background: #FFFFFF;
    border: 1px solid #D4D0C8;
    border-radius: 2px;
    outline: none;
    alternate-background-color: #FAF9F6;
}
QTreeWidget::item {
    padding: 8px 6px;
    border: none;
    min-height: 32px;
}
QTreeWidget::item:hover {
    background: #F5F2EB;
}
QTreeWidget::item:selected {
    background: rgba(146, 64, 14, 0.06);
    color: #141413;
}
QTreeWidget::branch {
    background: transparent;
}
QTreeWidget::branch:has-children:!has-siblings:closed,
QTreeWidget::branch:closed:has-children:has-siblings {
    border-image: none;
}
QTreeWidget::branch:open:has-children:!has-siblings,
QTreeWidget::branch:open:has-children:has-siblings {
    border-image: none;
}

/* ---- 消息框 ---- */
QMessageBox {
    background: #FAF9F6;
}
QMessageBox QLabel {
    color: #141413;
    font-size: 14px;
    min-width: 340px;
}
QMessageBox QPushButton {
    min-width: 88px;
    padding: 8px 20px;
}

/* ---- 工具提示 ---- */
QToolTip {
    background: #141413;
    color: #FAF9F6;
    border: none;
    border-radius: 0;
    padding: 8px 12px;
    font-size: 12px;
}

/* ---- 复选框 ---- */
QCheckBox {
    spacing: 10px;
    color: #141413;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #6B6B6B;
    border-radius: 0;
    background: #FFFFFF;
}
QCheckBox::indicator:hover {
    border-color: #92400E;
}
QCheckBox::indicator:checked {
    background: #141413;
    border-color: #141413;
}
QCheckBox::indicator:disabled {
    background: #F5F2EB;
    border-color: #D4D0C8;
}

/* ---- 单选框 ---- */
QRadioButton {
    spacing: 10px;
    color: #141413;
}
QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #6B6B6B;
    border-radius: 8px;
    background: #FFFFFF;
}
QRadioButton::indicator:hover {
    border-color: #92400E;
}
QRadioButton::indicator:checked {
    border: 5px solid #141413;
    background: #FFFFFF;
}
QRadioButton::indicator:disabled {
    background: #F5F2EB;
    border-color: #D4D0C8;
}

/* ---- 进度条：极简细线 ---- */
QProgressBar {
    border: none;
    border-radius: 0;
    background: #E8E5DE;
    text-align: center;
    color: #6B6B6B;
    font-size: 11px;
    min-height: 4px;
    max-height: 4px;
}
QProgressBar::chunk {
    background: #92400E;
    border-radius: 0;
}

/* ---- 日期选择器 ---- */
QDateTimeEdit {
    border: 1px solid #D4D0C8;
    border-radius: 2px;
    padding: 8px 14px;
    background: #FFFFFF;
    color: #141413;
    min-height: 36px;
}
QDateTimeEdit:hover {
    border-color: #6B6B6B;
}
QDateTimeEdit:focus {
    border-color: #92400E;
}
QDateTimeEdit::drop-down {
    border: none;
    width: 28px;
}
QDateTimeEdit::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #141413;
    margin-right: 10px;
}

/* ---- 分割线 ---- */
QFrame[frameShape="4"], QFrame[frameShape="5"] {
    color: #D4D0C8;
    max-height: 1px;
}

/* ---- SpinBox ---- */
QSpinBox, QDoubleSpinBox {
    border: 1px solid #D4D0C8;
    border-radius: 2px;
    padding: 8px 14px;
    background: #FFFFFF;
    color: #141413;
    min-height: 36px;
}
QSpinBox:hover, QDoubleSpinBox:hover {
    border-color: #6B6B6B;
}
QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: #92400E;
}
QSpinBox:disabled, QDoubleSpinBox:disabled {
    background: #F5F2EB;
    color: #9A9A9A;
    border-color: #E8E5DE;
}
QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    border: none;
    background: #FAF9F6;
    width: 20px;
}
QSpinBox::up-button:hover, QDoubleSpinBox::up-button:hover,
QSpinBox::down-button:hover, QDoubleSpinBox::down-button:hover {
    background: #E8E5DE;
}

/* ---- 状态栏 ---- */
QStatusBar {
    background: #141413;
    border-top: none;
    color: #9A9A9A;
    font-size: 12px;
}
QStatusBar::item { border: none; }

/* ---- 菜单栏 ---- */
QMenuBar {
    background: #FAF9F6;
    border-bottom: 1px solid #D4D0C8;
}
QMenuBar::item {
    padding: 10px 18px;
    background: transparent;
    color: #141413;
}
QMenuBar::item:selected {
    background: #141413;
    color: #FAF9F6;
}
QMenuBar::item:pressed {
    background: #0A0A0A;
}
QMenu {
    background: #FFFFFF;
    border: 1px solid #141413;
    border-radius: 0;
    padding: 4px 0;
}
QMenu::item {
    padding: 10px 28px;
    color: #141413;
}
QMenu::item:selected {
    background: #141413;
    color: #FAF9F6;
}
QMenu::separator {
    height: 1px;
    background: #E8E5DE;
    margin: 4px 8px;
}

/* ---- 工具按钮 ---- */
QToolButton {
    background: transparent;
    border: none;
    border-radius: 2px;
    padding: 6px;
    color: #6B6B6B;
}
QToolButton:hover {
    background: #F5F2EB;
    color: #141413;
}
QToolButton:pressed {
    background: #E8E5DE;
}
QToolButton:checked {
    background: #141413;
    color: #FAF9F6;
}

/* ---- 兼容保留 ---- */
/* 旧的 #1677ff 主蓝色不再主导，仅保留在必要链接场景 */
